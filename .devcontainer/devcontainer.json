{
	"name": "LBR Docker Container",
	"image": "lbr-build:latest",
	"build": {
		"dockerfile": "../Dockerfile",
		"context": "..",
		"args": {
			"BUILDKIT_INLINE_CACHE": "1"
		}
	},
	"runArgs": [
  "--device=/dev/bus/usb",
  "--device-cgroup-rule=c 189:* rmw"
	],
	"mounts": [
		"source=${localEnv:HOME}/.ssh,target=/root/.ssh,type=bind,readonly",
		"source=${localEnv:HOME}/.gitconfig,target=/root/.gitconfig,type=bind,readonly"
	],
	"forwardPorts": [
		  50000,
      50001,
      50002
	],
  "portsAttributes": {
    "50000": {
      "label": "GDB Debug Port",
      "onAutoForward": "notify"
    },
    "50001": {
      "label": "OpenOCD TCL",
      "onAutoForward": "notify"
    },
    "50002": {
      "label": "OpenOCD Telnet",
      "onAutoForward": "notify"
    }
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"mcu-debug.debug-tracker-vscode",
				"ms-vscode.cpptools",
				"ms-vscode.cpptools-extension-pack",
				"marus25.cortex-debug",
				"llvm-vs-code-extensions.vscode-clangd",
				"ms-vscode.cmake-tools",
				"ms-vscode.vscode-serial-monitor"
			],
			"settings": {
				"C_Cpp.default.cStandard": "c11",
				"C_Cpp.default.cppStandard": "c++17",
				"clangd.arguments": [
					"--header-insertion=iwyu",
					"--all-scopes-completion",
					"--background-index"
				],
				"[c]": {
					"editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
					"editor.formatOnSave": true
				},
				"[cpp]": {
					"editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
					"editor.formatOnSave": true
				},
				"files.exclude": {
					"build/": false,
					".cache/": true
				},
				"cmake.configureOnOpen": true,
				"cmake.showOutputOnError": true,
				"cortex-debug.armToolchainPath": "/usr/local/bin",
				"cortex-debug.gdbPath": "/usr/bin/gdb-multiarch",
				"cortex-debug.openocdPath": "/usr/bin/openocd"
			}
		}
	},
	"remoteUser": "root",	// Required for USB and OpenOCD access
	"workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
	"workspaceFolder": "/workspace",
	"postStartCommand": "echo 'Container started. Run: make.sh -t <preset>'",
	"postCreateCommand": "apt-get update && apt-get upgrade -y && apt-get clean",
	"remoteEnv": {
		"CMAKE_BUILD_PARALLEL_LEVEL": "4",
		"NINJA_STATUS": "%p [%c/%t]"
	}
}