{
	"name": "LBR Develop",
	"image": "lbr:latest",
	"build": {
		"dockerfile": "../../Dockerfile",
		"context": "..",
		"args": {
			"BUILDKIT_INLINE_CACHE": "1"
		}
	},
	"mounts": [
		"source=${localEnv:HOME}/.ssh,target=/home/dev/.ssh,type=bind,readonly",
		"source=${localEnv:HOME}/.gitconfig,target=/home/dev/.gitconfig,type=bind,readonly"
	],
	"forwardPorts": [
		50000,
		50001,
		50002
	],
	"portsAttributes": {
		"50000": {
			"label": "GDB Debug Port",
			"onAutoForward": "notify"
		},
		"50001": {
			"label": "OpenOCD TCL",
			"onAutoForward": "notify"
		},
		"50002": {
			"label": "OpenOCD Telnet",
			"onAutoForward": "notify"
		}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"mcu-debug.debug-tracker-vscode",
				"marus25.cortex-debug",
				"llvm-vs-code-extensions.vscode-clangd",
				"ms-vscode.cmake-tools",
				"bbenoist.doxygen",
				"ms-vscode.hexeditor",
				"mcu-debug.memory-view",
				"mcu-debug.rtos-views",
				"mcu-debug.peripheral-viewer",
				"ms-vscode.vscode-serial-monitor"
			],
			"settings": {
				"C_Cpp.default.cStandard": "gnu17",
				"C_Cpp.default.cppStandard": "gnu++20",
				"clangd.arguments": [
					"--header-insertion=iwyu",
					"--all-scopes-completion",
					"--background-index"
				],
				"[c]": {
					"editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
					"editor.formatOnSave": true
				},
				"[cpp]": {
					"editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
					"editor.formatOnSave": true
				},
				"files.exclude": {
					"build/": false,
					".cache/": true
				},
				"cmake.configureOnOpen": true,
				"cmake.showOutputOnError": true,
				"cortex-debug.armToolchainPath": "/usr/local/bin",
				"cortex-debug.gdbPath": "/usr/bin/gdb-multiarch",
				"cortex-debug.openocdPath": "/usr/bin/openocd"
			}
		}
	},
	"runArgs": [
		"--hostname=dev"
	],
	"remoteUser": "lbr",
	"workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
	"workspaceFolder": "/workspace",
	"postStartCommand": "echo 'Container started. Run: make.sh -t <preset>'",
	"postCreateCommand": "sudo apt-get update && sudo apt-get upgrade -y && sudo apt-get clean",
	"remoteEnv": {
		"CMAKE_BUILD_PARALLEL_LEVEL": "4",
		"NINJA_STATUS": "%p [%c/%t]"
	},
	"updateRemoteUserUID": true
}